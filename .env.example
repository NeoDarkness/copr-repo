# GitHub Secrets Configuration Template
# 
# Add these secrets to your GitHub repository:
# Settings → Secrets and variables → Actions → New repository secret
#
# For help getting these values, see CI-CD-SETUP.md

# Your COPR username (visible in https://copr.fedorainfracloud.org/api/)
COPR_USERNAME=your-username-here

# Your COPR API login token (from https://copr.fedorainfracloud.org/api/)
COPR_LOGIN=your-login-token-here

# Your COPR API token (from https://copr.fedorainfracloud.org/api/)
COPR_TOKEN=your-copr-token-here

# Your COPR repository in format: username/repo-name
COPR_REPO=username/repo-name
